# Shared DB (same as muai)
DB_URL=postgresql+asyncpg://bot:changeme@db:5432/tgbot

# Orchestrator Telegram bot token (main VERA bot)
MAIN_BOT_TOKEN=

# Owner Telegram ID (same as muai)
OWNER_TELEGRAM_ID=

# Virtual office supergroup ID (negative number)
OFFICE_GROUP_ID=

# LLM — reads from shared api_tokens table in DB
# Optional seed key: if DB has no gemini tokens on first start, this is inserted automatically
GEMINI_API_KEY=

# muai API (for TelegramKB agent RAG calls)
MUAI_API_URL=http://bot:8000
MUAI_API_SECRET=

LOG_LEVEL=INFO

# All other service credentials (Poster, Trello, Gmail, Instagram, Perplexity, etc.)
# are managed via the admin UI and stored in the tool_credentials DB table.
